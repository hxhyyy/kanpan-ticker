{
  "name": "kanpan-ticker",
  "displayName": "看盘插件",
  "description": "在 VS Code / Cursor 状态栏和侧边栏查看美股和比特币实时价格",
  "version": "0.2.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/kanpan-ticker"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:kanpanView.stock",
    "onView:kanpanView.crypto",
    "onView:kanpanView.settings"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kanpanMenu",
          "title": "看盘插件",
          "icon": "resources/kanpan.svg"
        }
      ]
    },
    "views": {
      "kanpanMenu": [
        {
          "id": "kanpanView.stock",
          "name": "Stock"
        },
        {
          "id": "kanpanView.crypto",
          "name": "Crypto"
        },
        {
          "id": "kanpanView.settings",
          "name": "Settings"
        }
      ]
    },
    "commands": [
      {
        "command": "kanpan.refresh",
        "title": "看盘插件: 立即刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "kanpan.show",
        "title": "看盘插件: 显示状态栏"
      },
      {
        "command": "kanpan.hide",
        "title": "看盘插件: 隐藏状态栏"
      },
      {
        "command": "kanpan.addStock",
        "title": "看盘插件: 添加美股",
        "icon": "$(add)"
      },
      {
        "command": "kanpan.addCrypto",
        "title": "看盘插件: 添加加密货币",
        "icon": "$(add)"
      },
      {
        "command": "kanpan.removeStock",
        "title": "删除美股",
        "icon": "$(trash)"
      },
      {
        "command": "kanpan.removeCrypto",
        "title": "删除加密货币",
        "icon": "$(trash)"
      },
      {
        "command": "kanpan.openSettings",
        "title": "打开设置",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kanpan.refresh",
          "when": "view == kanpanView.stock || view == kanpanView.crypto",
          "group": "navigation"
        },
        {
          "command": "kanpan.addStock",
          "when": "view == kanpanView.stock",
          "group": "navigation"
        },
        {
          "command": "kanpan.addCrypto",
          "when": "view == kanpanView.crypto",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kanpan.removeStock",
          "when": "view == kanpanView.stock && viewItem == usStock",
          "group": "inline"
        },
        {
          "command": "kanpan.removeCrypto",
          "when": "view == kanpanView.crypto && viewItem == crypto",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "看盘插件",
      "properties": {
        "kanpan.stocks": {
          "type": "array",
          "default": ["AAPL", "NVDA", "TSLA"],
          "description": "要监控的美股代码（Finnhub）"
        },
        "kanpan.cryptoSymbols": {
          "type": "array",
          "default": ["BTCUSDT"],
          "description": "Binance 交易对，如 BTCUSDT、ETHUSDT"
        },
        "kanpan.finnhubApiKey": {
          "type": "string",
          "default": "",
          "description": "Finnhub API Key（美股必需，免费注册 https://finnhub.io）"
        },
        "kanpan.refreshInterval": {
          "type": "number",
          "default": 10000,
          "minimum": 5000,
          "description": "刷新间隔（毫秒，最小 5000）"
        },
        "kanpan.riseColor": {
          "type": "string",
          "default": "#26a69a",
          "description": "上涨颜色"
        },
        "kanpan.fallColor": {
          "type": "string",
          "default": "#ef5350",
          "description": "下跌颜色"
        },
        "kanpan.showChangePercent": {
          "type": "boolean",
          "default": true,
          "description": "显示涨跌幅"
        },
        "kanpan.monochrome": {
          "type": "boolean",
          "default": false,
          "description": "隐身模式：隐藏涨跌颜色和箭头"
        },
        "kanpan.format": {
          "type": "string",
          "default": "{symbol} {price} {change} {icon}",
          "description": "状态栏格式，占位符: {symbol} {price} {change} {icon}"
        },
        "kanpan.aliases": {
          "type": "object",
          "default": {},
          "description": "别名映射，如 {\"BTCUSDT\": \"BTC\"}"
        },
        "kanpan.onlyRefreshWhenFocused": {
          "type": "boolean",
          "default": false,
          "description": "仅在窗口聚焦时刷新"
        },
        "kanpan.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用状态栏显示"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0"
  }
}
